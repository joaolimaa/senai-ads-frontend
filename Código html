<!doctype html>
<!-- Informa ao navegador que este documento usa HTML5 -->
<html lang="pt-br">
<!-- Início do documento HTML e definição do idioma como português do Brasil -->

<head>
  <!-- Parte de configurações da página, que não aparece diretamente no conteúdo -->
  <meta charset="UTF-8" />
  <!-- Permite usar acentos e caracteres especiais corretamente -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Faz a página se adaptar melhor a telas menores -->
  <title>CGGAMES</title>
  <!-- Título que aparece na aba do navegador -->
  <link rel="icon" href="./assets/CG.ico" />
  <!-- Ícone da página que aparece ao lado do título na aba -->
  <link rel="stylesheet" href="CGGAMES.css" />
